PORT=3000
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_SEARCH_MODEL=gpt-4o

# Optional hard gate for public deployments. If set, callers must pass this
# value in the x-demo-access-token header.
DEMO_ACCESS_TOKEN=

# Live Google actions are disabled by default. Keep this false for a public
# portfolio demo unless you have a tight recipient allowlist.
ENABLE_LIVE_GAS=false
GAS_ENDPOINT=https://script.google.com/macros/s/.../exec
GAS_TOKEN=replace-me
ALLOWED_GAS_ACTIONS=create_doc,send_email,create_event
ALLOWED_EMAIL_RECIPIENTS=your-demo-inbox@example.com
DEFAULT_EMAIL_RECIPIENT=your-demo-inbox@example.com
DEMO_FROM_NAME=Agent Orchestration Demo
